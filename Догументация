Примеры запросов
JavaScript (Fetch API)
javascript
const API_URL = 'http://127.0.0.1:8001';

// ============================================
// 1. ВХОД
// ============================================
async function login(email, password) {
    const formData = new URLSearchParams();
    formData.append('username', email);
    formData.append('password', password);

    const response = await fetch(`${API_URL}/token`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData
    });

    const data = await response.json();
    localStorage.setItem('access_token', data.access_token);
    return data;
}

// ============================================
// 2. ЗАПРОС С ТОКЕНОМ
// ============================================
async function apiRequest(url, options = {}) {
    const token = localStorage.getItem('access_token');
    const response = await fetch(`${API_URL}${url}`, {
        ...options,
        headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`,
            ...options.headers
        }
    });
    return response;
}

// ============================================
// 3. ПОЛУЧИТЬ ТАРИФЫ
// ============================================
async function getTariffs() {
    const response = await apiRequest('/tariffs');
    return await response.json();
}

// ============================================
// 4. ОФОРМИТЬ ПОДПИСКУ
// ============================================
async function createSubscription(tariffId) {
    const response = await apiRequest(`/subscriptions?tariff_id=${tariffId}`, {
        method: 'POST'
    });
    return await response.json();
}

// ============================================
// 5. ПОЛУЧИТЬ ТЕКУЩУЮ ПОДПИСКУ
// ============================================
async function getCurrentSubscription() {
    const response = await apiRequest('/subscriptions/me');
    if (response.status === 404) return null;
    return await response.json();
}

// ============================================
// 6. ПОЛУЧИТЬ ИСТОРИЮ ПЛАТЕЖЕЙ
// ============================================
async function getPayments(subscriptionId, startDate = '', endDate = '') {
    let url = `/payments?subscription_id=${subscriptionId}`;
    if (startDate) url += `&start_date=${startDate}`;
    if (endDate) url += `&end_date=${endDate}`;
    
    const response = await apiRequest(url);
    return await response.json();
}

// ============================================
// 7. СМЕНИТЬ ТАРИФ
// ============================================
async function changeTariff(subscriptionId, newTariffId) {
    const response = await apiRequest(
        `/subscriptions/${subscriptionId}/change-tariff?new_tariff_id=${newTariffId}`,
        { method: 'PUT' }
    );
    return await response.json();
}

// ============================================
// 8. ОТМЕНИТЬ ПОДПИСКУ
// ============================================
async function cancelSubscription(subscriptionId) {
    const response = await apiRequest(`/subscriptions/${subscriptionId}/cancel`, {
        method: 'PUT'
    });
    return await response.json();
}

// ============================================
// 9. ПРИОСТАНОВИТЬ ПОДПИСКУ
// ============================================
async function pauseSubscription(subscriptionId) {
    const response = await apiRequest(`/subscriptions/${subscriptionId}/pause`, {
        method: 'PUT'
    });
    return await response.json();
}

// ============================================
// 10. ВОЗОБНОВИТЬ ПОДПИСКУ
// ============================================
async function resumeSubscription(subscriptionId) {
    const response = await apiRequest(`/subscriptions/${subscriptionId}/resume`, {
        method: 'PUT'
    });
    return await response.json();
}
Коды ошибок
Код	Описание	Что делать
200	Успех	Обрабатывай ответ
400	Неверные параметры	Проверь данные запроса
401	Требуется аутентификация	Перенаправь на страницу входа
403	Недостаточно прав	Покажи сообщение "Доступ запрещён"
404	Объект не найден	Покажи сообщение "Не найдено"
422	Ошибка валидации	Проверь формат данных
500	Внутренняя ошибка	Покажи "Что-то пошло не так"
Чек-лист интеграции
✅ Страница входа (login.html)
Форма с полями email и password

При отправке вызывается login()

Токен сохраняется в localStorage

После успешного входа — переход на account.html

✅ Каталог тарифов (plans.html)
При загрузке вызывается getTariffs()

Карточки тарифов отображаются

При клике на карточку — выбирается тариф

Кнопка "Оформить" вызывает createSubscription()

✅ Личный кабинет (account.html)
При загрузке вызывается getCurrentSubscription()

Отображаются: тариф, статус, дата списания

Кнопка "Сменить тариф" → переход на plans.html?change=true

Кнопка "Приостановить" → pauseSubscription()

Кнопка "Возобновить" → resumeSubscription()

Кнопка "Отменить" → cancelSubscription()

История платежей → getPayments()

Фильтры по дате работают

✅ Админка (admin.html)
Доступна только администраторам

Графики статусов подписок

Список всех подписок с кнопками действий

Отчёт по выручке с группировкой по месяцам

Частые проблемы и решения
1. CORS ошибка
text
Access to fetch at 'http://127.0.0.1:8001/...' from origin 'http://127.0.0.1:5500' has been blocked
Решение: Убедись, что бэкенд запущен с CORS-настройками.

2. 401 Unauthorized
json
{"detail": "Not authenticated"}
Решение: Токен не передан или истёк. Перенаправь на страницу входа.

3. В истории нет платежей
Решение: Создай тестовые платежи через Swagger или pgAdmin.

